# ===========================================
# ASSET STUDIO - API KEYS
# ===========================================
#
# WICHTIG: Kopiere diese Datei zu .env.local
#          und füge deine echten API Keys ein.
#
# NIEMALS .env.local committen! (steht in .gitignore)
#
# Hinweis: Keys können auch direkt in der Tool-UI (Einstellungen)
#          eingegeben werden; diese .env.local-Werte sind der Fallback.
# ===========================================

# Google AI (Nano Banana Pro / Gemini) — Bild-Generierung
# Holen unter: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API (Anthropic) — optionale Prompt-Verbesserung
# Holen unter: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs — Audio (TTS / SFX / Musik); benötigt ab Milestone M5
# Holen unter: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# OPTIONALE EINSTELLUNGEN (Defaults in src/lib/constants.ts)
# ===========================================

# Bild-Modell (default: gemini-3-pro-image = Nano Banana Pro)
# NANO_BANANA_MODEL=gemini-3-pro-image

# Claude Modell (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Max Bilder pro Generierung (default: 4)
# MAX_IMAGES_PER_GENERATION=4

# ===========================================
# ZUGRIFFSSCHUTZ (nur für die gehostete Instanz)
# ===========================================
# App-weites Passwort (Basic Auth) für Seiten UND /api/*.
# - Lokal (npm run dev): kann leer bleiben → kein Gate beim Entwickeln.
# - Gehostet: MUSS gesetzt sein, sonst blockt die App (kein offenes Deploy).
#   Diese Werte im Dashboard des Hosters (Vercel/Netlify) eintragen, NICHT hier.
# SITE_USER=admin
# SITE_PASSWORD=ein-langes-zufaelliges-passwort
